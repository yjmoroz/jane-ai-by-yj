{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "jane-ai-by-yj",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat_v2"],
  "ai": { "binding": "AI", "remote": true },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
