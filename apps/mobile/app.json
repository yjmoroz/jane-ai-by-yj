{
  "expo": {
    "name": "Jane AI by YJ",
    "slug": "jane-ai-by-yj",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "janeai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yjmoroz.janeaibyyj",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Jane AI by YJ records your session audio so it can be transcribed and turned into a SOAP note. Audio leaves your device only when you tap record."
      }
    },
    "android": {
      "package": "com.yjmoroz.janeaibyyj",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Jane AI by YJ records your session audio so it can be transcribed and turned into a SOAP note."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e95b61eb-6b89-4d89-b28e-a87a98f2ab5f"
      }
    },
    "owner": "pads_vowels6g",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e95b61eb-6b89-4d89-b28e-a87a98f2ab5f"
    }
  }
}
